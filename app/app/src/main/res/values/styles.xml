<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="ShapeAppearance.App" parent="ShapeAppearance.MaterialComponents.MediumComponent" />

    <style name="ShapeAppearance.App.CircleImageView" parent="ShapeAppearance.App">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="TextAppearance.Piratas.Title" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">@font/pirata</item>
        <item name="android:textColor">@color/anaranjado</item>
    </style>

    <style name="TextAppearance.Piratas.Section" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:fontFamily">@font/pirata</item>
        <item name="android:textColor">@color/anaranjado</item>
    </style>

    <style name="TextAppearance.Piratas.Button" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:fontFamily">@font/pirata</item>
        <item name="android:textColor">@color/blanco</item>
        <item name="android:textSize">20sp</item>
    </style>

    <style name="Widget.PiratasDeAndromeda.PrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/btnclaro</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@color/blanco</item>
        <item name="android:fontFamily">@font/pirata</item>
        <item name="android:textSize">20sp</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="Widget.PiratasDeAndromeda.ClassicButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/btnclaro</item>
        <item name="android:backgroundTint">@null</item>
        <item name="android:textColor">@color/blanco</item>
        <item name="android:fontFamily">@font/pirata</item>
        <item name="android:textSize">20sp</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
    </style>

    <style name="Widget.PiratasDeAndromeda.DarkButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/btnoscuro</item>
        <item name="android:backgroundTint">@android:color/transparent</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="android:foreground">@null</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:textColor">@color/blanco</item>
        <item name="android:fontFamily">@font/pirata</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">center</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
    </style>


    <style name="Widget.PiratasDeAndromeda.SecondaryButton" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/btnoscuro</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@color/blanco</item>
        <item name="android:fontFamily">@font/pirata</item>
        <item name="android:textSize">18sp</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="Widget.PiratasDeAndromeda.CircleIconButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">48dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:elevation">0dp</item>
        <item name="android:background">@drawable/btnoscuro</item>
        <item name="backgroundTint">@null</item>
        <item name="shapeAppearance">@style/ShapeAppearance.App.CircleImageView</item>
    </style>

    <style name="Widget.PiratasDeAndromeda.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundMode">none</item>
        <item name="hintTextColor">@color/anaranjado</item>
        <item name="boxStrokeColor">@color/borde_edittext</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">1dp</item>
    </style>

    <style name="Widget.PiratasDeAndromeda.TextInputEditText" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:background">@drawable/edittext</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:textColor">@color/anaranjado</item>
        <item name="android:textColorHint">@color/anaranjado</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="Widget.PiratasDeAndromeda.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/outline_soft</item>
        <item name="cardBackgroundColor">@color/surface_variant_dark</item>
    </style>



</resources>


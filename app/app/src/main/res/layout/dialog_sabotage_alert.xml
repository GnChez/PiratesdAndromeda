<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/btnoscuro"
    android:padding="28dp">

    <ImageView
        android:id="@+id/ivSabotageWarning"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:src="@drawable/ic_close"
        android:contentDescription="Advertencia de sabotaje"
        android:padding="16dp"
        android:background="@drawable/btn_icon_circle"
        app:tint="@color/blanco"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvSabotageTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="¡SALA SABOTEADA!"
        android:textColor="@color/blanco"
        android:textAlignment="center"
        android:fontFamily="@font/pirata"
        android:textSize="36sp"
        app:layout_constraintTop_toBottomOf="@id/ivSabotageWarning"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvSabotageRoomName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/blanco"
        android:textAlignment="center"
        android:textSize="18sp"
        android:fontFamily="@font/pirata"
        android:alpha="0.85"
        app:layout_constraintTop_toBottomOf="@id/tvSabotageTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvSabotageMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="La misión ha sido interrumpida. Debes detener la actividad."
        android:textColor="@color/blanco"
        android:textAlignment="center"
        android:textSize="14sp"
        android:alpha="0.7"
        android:lineSpacingMultiplier="1.3"
        app:layout_constraintTop_toBottomOf="@id/tvSabotageRoomName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvSabotageCountdown"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="8dp"
        android:textColor="@color/blanco"
        android:textAlignment="center"
        android:fontFamily="@font/pirata"
        android:textSize="48sp"
        android:text="15"
        app:layout_constraintTop_toBottomOf="@id/tvSabotageMessage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/backgroundbasic"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvConfigTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/config_part_title"
            android:textAppearance="@style/TextAppearance.Piratas.Title"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageButton
            android:id="@+id/btnCloseSession"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/btn_icon_circle"
            android:contentDescription="@string/start_fr_profile_cd"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/perfil"
            app:tint="@color/blanco"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvSavedShipsLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/config_saved_ships"
            android:textAppearance="@style/TextAppearance.Piratas.Section"
            app:layout_constraintTop_toBottomOf="@id/tvConfigTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSavedShips"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false"
            tools:listitem="@layout/item_saved_ship"
            tools:itemCount="2"
            app:layout_constraintTop_toBottomOf="@id/tvSavedShipsLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvShipNameLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/config_ship_name_label"
            android:textAppearance="@style/TextAppearance.Piratas.Section"
            app:layout_constraintTop_toBottomOf="@id/rvSavedShips"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/edShipName"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/edittext"
            android:hint="@string/config_ship_name_hint"
            android:inputType="textCapWords"
            android:autofillHints="name"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/anaranjado"
            android:textColorHint="@color/anaranjado"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/tvShipNameLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnCrear" />

        <Button
            android:id="@+id/btnCrear"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_marginStart="8dp"
            android:text="@string/start_fr_create_button"
            android:background="@drawable/btnclaro"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:gravity="center"
            android:fontFamily="@font/pirata"
            android:textColor="@color/blanco"
            android:textSize="20sp"
            app:layout_constraintTop_toTopOf="@id/edShipName"
            app:layout_constraintBottom_toBottomOf="@id/edShipName"
            app:layout_constraintStart_toEndOf="@id/edShipName"
            app:layout_constraintEnd_toEndOf="parent" />


        <TextView
            android:id="@+id/tvCodeInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/config_code_label"
            android:textAppearance="@style/TextAppearance.Piratas.Section"
            app:layout_constraintBottom_toTopOf="@+id/edUnirseCode"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="16dp"
            />

        <EditText
            android:id="@+id/edUnirseCode"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:background="@drawable/edittext"
            android:hint="@string/config_code_hint"
            android:inputType="textCapWords"
            android:autofillHints="password"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="20dp"
            android:textColor="@color/anaranjado"
            android:textColorHint="@color/anaranjado"
            android:textSize="16sp"
            app:layout_constraintBottom_toTopOf="@id/btnUnirme"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnCrear" />

        <ImageButton
            android:id="@+id/btnCancel"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/btn_icon_circle"
            android:contentDescription="@string/cd_cancel"
            android:padding="0dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_close"
            app:tint="@color/blanco"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <Button
            android:id="@+id/btnUnirme"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="24dp"
            android:text="@string/config_join_button"
            android:background="@drawable/btnclaro"
            app:backgroundTint="@null"
            android:gravity="center"
            android:fontFamily="@font/pirata"
            android:textColor="@color/blanco"
            android:textSize="20sp"
            app:layout_constraintStart_toEndOf="@id/btnCancel"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
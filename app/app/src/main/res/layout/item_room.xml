<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRoomName"
        style="@style/Widget.PiratasDeAndromeda.PrimaryButton"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text=""
        app:cornerRadius="26dp"
        tools:text="Cocina"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnDeleteRoom" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDeleteRoom"
        style="@style/Widget.PiratasDeAndromeda.CircleIconButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="12dp"
        android:padding="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        app:icon="@drawable/ic_close"
        app:iconSize="18dp"
        app:iconPadding="0dp"
        app:iconGravity="textStart"
        android:contentDescription="@string/cd_delete_room"
        app:shapeAppearance="@style/ShapeAppearance.App.CircleImageView"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnRoomName" />

</androidx.constraintlayout.widget.ConstraintLayout>
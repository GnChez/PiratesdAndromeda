<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/btnclaro"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvDeleteDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/pirata"
        android:text="@string/delete_ship_dialog_title"
        android:textColor="@color/blanco"
        android:textSize="24sp" />

    <TextView
        android:id="@+id/tvDeleteDialogMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/pirata"
        android:text="@string/delete_ship_dialog_message"
        android:textColor="@color/blanco"
        android:textSize="18sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDialogCancel"
            style="@style/Widget.PiratasDeAndromeda.DarkButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/delete_ship_dialog_cancel" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDialogConfirm"
            style="@style/Widget.PiratasDeAndromeda.DarkButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="@string/delete_ship_dialog_confirm" />
    </LinearLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/backgroundbasic"
    android:padding="16dp">

    <!-- ── TÍTULO ── -->

    <TextView
        android:id="@+id/tvJuegoProcesoTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="80dp"
        android:text="@string/juego_proceso_title"
        android:textAppearance="@style/TextAppearance.Piratas.Title"
        tools:text="Juego en proceso"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── PUNTOS DEL JUGADOR (ARRIBA DERECHA) ── -->

    <TextView
        android:id="@+id/tvPuntosJugador"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/btn_icon_circle"
        android:gravity="center"
        android:padding="12dp"
        android:text="0"
        android:textColor="@color/blanco"
        android:textSize="18sp"
        android:fontFamily="@font/pirata"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="250" />

    <!-- ── CARD CONTENIDO ── -->

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardProceso"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="88dp"
        app:cardBackgroundColor="#CC3B1010"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvJuegoProcesoTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

            <!-- Nombre de la tarea -->
            <TextView
                android:id="@+id/tvTareaNombre"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:fontFamily="@font/pirata"
                android:textColor="@color/anaranjado"
                android:textSize="20sp"
                tools:text="Arreglar luces"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- WebView centrado -->
            <WebView
                android:id="@+id/webViewGame"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/tvTareaNombre"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- ── BOTÓN CERRAR (ABAJO IZQUIERDA) ── -->

    <ImageButton
        android:id="@+id/btnClose"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/btn_icon_circle"
        android:contentDescription="@string/cd_close"
        android:padding="10dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_close"
        app:tint="@color/blanco"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>


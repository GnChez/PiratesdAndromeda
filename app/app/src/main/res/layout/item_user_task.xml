<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="8dp"
    android:paddingVertical="8dp">

    <!-- ── CHECKBOX COMPLETADA (izquierda) ── -->

    <CheckBox
        android:id="@+id/cbTareaCompletada"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:buttonTint="@color/anaranjado"
        android:contentDescription="@string/cd_task_done"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ── NOMBRE DE LA TAREA ── -->

    <TextView
        android:id="@+id/tvTareaNombre"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:fontFamily="@font/pirata"
        android:textColor="@color/blanco"
        android:textSize="16sp"
        android:gravity="center_vertical"
        tools:text="Arregla luces"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/cbTareaCompletada"
        app:layout_constraintEnd_toStartOf="@id/btnComenzarTarea" />

    <!-- ── BOTÓN COMENZAR (derecha) ── -->

    <Button
        android:id="@+id/btnComenzarTarea"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:text="@string/labores_item_start_button"
        android:background="@drawable/btnclaro"
        android:backgroundTint="@null"
        app:backgroundTint="@null"
        android:fontFamily="@font/pirata"
        android:textColor="@color/blanco"
        android:textSize="12sp"
        android:paddingHorizontal="16dp"
        android:contentDescription="@string/cd_task_start"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>


<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvHeroTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="12dp"
            android:text="@string/config_rooms_title"
            android:textAppearance="@style/TextAppearance.Piratas.Title"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Subtitle overlay at bottom of hero -->
        <TextView
            android:id="@+id/tvConfigLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="8dp"
            android:text="@string/config_rooms_subtitle"
            android:textAppearance="@style/TextAppearance.Piratas.Section"
            app:layout_constraintTop_toBottomOf="@id/tvHeroTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Divider -->
        <View
            android:id="@+id/dividerHero"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="?attr/colorOutlineVariant"
            app:layout_constraintTop_toBottomOf="@id/tvConfigLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Rooms RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRooms"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="16dp"
            android:nestedScrollingEnabled="false"
            android:clipToPadding="false"
            tools:listitem="@layout/item_room"
            tools:itemCount="3"
            app:layout_constraintTop_toBottomOf="@id/dividerHero"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Add room: input + "+" button -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilRoomName"
            style="@style/Widget.PiratasDeAndromeda.TextInputLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="12dp"
            android:hint="@string/config_room_name_hint"
            app:layout_constraintTop_toBottomOf="@id/rvRooms"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnAddRoom">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edRoomName"
                style="@style/Widget.PiratasDeAndromeda.TextInputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords"
                android:imeOptions="actionDone" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddRoom"
            style="@style/Widget.PiratasDeAndromeda.CircleIconButton"
            android:layout_width="48dp"
            android:layout_height="0dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="20dp"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:text="@string/add_symbol"
            android:textAppearance="@style/TextAppearance.Piratas.Section"
            android:contentDescription="@string/cd_add_room"
            app:layout_constraintTop_toTopOf="@id/tilRoomName"
            app:layout_constraintBottom_toBottomOf="@id/tilRoomName"
            app:layout_constraintStart_toEndOf="@id/tilRoomName"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Bottom actions: X + Siguiente -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="@style/Widget.PiratasDeAndromeda.CircleIconButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:icon="@drawable/ic_close"
            app:iconSize="20dp"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            android:contentDescription="@string/cd_cancel"
            app:shapeAppearance="@style/ShapeAppearance.App.CircleImageView"
            app:layout_constraintTop_toBottomOf="@id/tilRoomName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSiguiente"
            style="@style/Widget.PiratasDeAndromeda.PrimaryButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp"
            android:text="@string/config_next_button"
            app:layout_constraintTop_toBottomOf="@id/tilRoomName"
            app:layout_constraintStart_toEndOf="@id/btnCancel"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintBaseline_toBaselineOf="@id/btnCancel" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
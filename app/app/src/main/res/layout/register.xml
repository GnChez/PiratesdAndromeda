<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:fontFamily="@font/pirata"
    tools:context=".RegisterFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="270dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="330dp"
        android:paddingHorizontal="30dp"
        >

        <TextView
            android:id="@+id/tvRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/pirata"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:text="@string/signUp"
            android:textColor="@color/anaranjado"
            android:textSize="50sp"
            android:maxLines="1" />


        <TextView
            android:id="@+id/tvLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/pirata"
            android:layout_marginTop="12dp"
            android:layout_marginStart="15dp"
            android:text="@string/login_subrallado"
            android:contentDescription="@string/go_to_login_cd"
            app:layout_constraintStart_toEndOf="@id/tvRegister"
            app:layout_constraintTop_toTopOf="parent"
            android:textColor="@color/sombra_naranja"
            android:textSize="30sp"
            />

        <LinearLayout
        android:id="@+id/llLoginContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@+id/tvRegister"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        >

        <EditText
            android:id="@+id/etUsuari"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/edittext"
            android:textColorHint="@color/anaranjado"
            android:hint="@string/correo"
            android:layout_gravity="start"
            android:autofillHints="emailAddress"
            android:inputType="text"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/anaranjado"
            android:textSize="16sp" />


        <EditText
            android:id="@+id/etUserName"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="10dp"
            android:hint="@string/usuari"
            android:autofillHints="username"
            android:inputType="text"
            android:background="@drawable/edittext"
            android:textColorHint="@color/anaranjado"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/anaranjado"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etContrasenya"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="10dp"
            android:hint="@string/contrasenya"
            android:autofillHints="password"
            android:inputType="textPassword"
            android:background="@drawable/edittext"
            android:textColorHint="@color/anaranjado"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/anaranjado"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etContrasenyaRep"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="32dp"
            android:hint="@string/repContrasenya"
            android:autofillHints="password"
            android:inputType="textPassword"
            android:background="@drawable/edittext"
            android:textColorHint="@color/anaranjado"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/anaranjado"
            android:textSize="16sp" />



    </LinearLayout>


    <Button
        android:id="@+id/btnRegistrate"
        android:layout_width="200dp"
        android:layout_height="60dp"
        style="@style/Widget.PiratasDeAndromeda.SecondaryButton"
        app:layout_constraintTop_toBottomOf="@+id/llLoginContainer"
        android:text="@string/btn_registrate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:textSize="25sp"
        />


    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>